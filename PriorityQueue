                 */
                Node2 k = tail;
                while(k.value > x) {
                    k = k.previous;
                }
                k.next.previous = n;
                n.next = k.next;
                n.previous = k;
                k.next = n;
                qanak++;
            }
        }
    }

    public boolean equals(PriorityQueue a){
        if(qanak != a.qanak){
            return false;
        }
        Node2 n = head;
        Node2 m = a.head;
        for(int i = 0; i < qanak; i++){
            if(n.value != m.value){
                return false;
            }
            n = n.next;
            m = m.next;
        }
        return true;
    }
