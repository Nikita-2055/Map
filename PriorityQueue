    void push(int x){
        Node2 n = new Node2(x);
        if(head == null){
            head = n;
            tail = n;
            qanak++;
        }else{
            if(n.value < head.value){
                head.previous = n;
                n.next = head;
                head = n;
                qanak++;
                return;
            }else if(n.value > tail.value){
                tail.next = n;
                n.previous = tail;
                tail = n;
                qanak++;
                return;
            }else{
                /*Node2 k = head;
                while(k != null){
                    if(k.value > x){
                        k.previous.next = n;
                        n.previous = k.previous;
